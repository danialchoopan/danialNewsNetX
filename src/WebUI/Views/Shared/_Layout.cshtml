<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - danialNewsNetX</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@100;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Vazirmatn', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">
    <div id="announcement-banner" class="hidden bg-amber-500 text-white py-2 px-4 text-center font-bold sticky top-0 z-50 transition-all">
        <span id="announcement-text"></span>
    </div>

    <header class="bg-white border-b border-slate-200">
        <nav class="container mx-auto px-4 py-4 flex justify-between items-center">
            <a class="text-2xl font-bold text-indigo-600" asp-area="" asp-controller="Home" asp-action="Index">danialNewsNetX</a>
            <div class="flex gap-4">
                <a class="text-slate-600 hover:text-indigo-600" asp-controller="Home" asp-action="Index">خانه</a>
                @if (User.IsInRole("SuperAdmin"))
                {
                    <a class="text-indigo-600 font-bold" asp-controller="SuperAdmin" asp-action="Index">پنل مدیریت</a>
                }
            </div>
        </nav>
    </header>

    <main role="main" class="container mx-auto px-4 py-8">
        @RenderBody()
    </main>

    <footer class="border-t border-slate-200 bg-white py-8">
        <div class="container mx-auto px-4 text-center text-slate-500">
            &copy; 2026 - danialNewsNetX
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/adminHub")
            .build();

        connection.on("ReceiveAnnouncement", function (message) {
            const banner = document.getElementById("announcement-banner");
            const text = document.getElementById("announcement-text");
            text.innerText = message;
            banner.classList.remove("hidden");
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
