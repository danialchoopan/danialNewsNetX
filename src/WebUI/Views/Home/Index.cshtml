@{
    ViewData["Title"] = "خوش آمدید";
}

<div class="min-h-screen">
    <!-- Hero Section -->
    <div class="relative overflow-hidden bg-slate-900 pt-16 pb-32 lg:pt-32 lg:pb-48">
        <div class="absolute inset-0">
            <div class="absolute inset-0 bg-gradient-to-br from-indigo-900/50 via-slate-900 to-emerald-900/30"></div>
            <div class="absolute top-0 right-0 -mt-20 -mr-20 w-96 h-96 bg-indigo-500/10 rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 left-0 -mb-20 -ml-20 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl"></div>
        </div>

        <div class="relative container mx-auto px-6 text-center">
            <h1 class="text-5xl lg:text-7xl font-black text-white mb-8 tracking-tight">
                نسل جدید <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-emerald-400">اخبار و گفتگو</span>
            </h1>
            <p class="max-w-2xl mx-auto text-xl text-slate-400 mb-12 leading-relaxed">
                پلتفرم danialNewsNetX سریع‌ترین راه برای اشتراک‌گذاری لحظات و دریافت اخبار روز دنیاست. بدون محدودیت، بلادرنگ و کاملاً مدرن.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="/feed" class="px-10 py-4 bg-indigo-600 hover:bg-indigo-500 text-white rounded-2xl font-bold text-lg shadow-xl shadow-indigo-600/20 transition-all transform hover:-translate-y-1">مشاهده فید زنده</a>
                <a href="#" class="px-10 py-4 bg-slate-800 hover:bg-slate-700 text-white border border-slate-700 rounded-2xl font-bold text-lg transition-all">ایجاد حساب کاربری</a>
            </div>
        </div>
    </div>

    <!-- Features Grid -->
    <div class="bg-white py-24">
        <div class="container mx-auto px-6">
            <div class="grid md:grid-cols-3 gap-12">
                <div class="p-8 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-2xl hover:shadow-indigo-500/10">
                    <div class="w-14 h-14 bg-indigo-600/10 text-indigo-600 rounded-2xl flex items-center justify-center mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-4">ارتباط بلادرنگ</h3>
                    <p class="text-slate-600 leading-relaxed">با استفاده از تکنولوژی SignalR، تمام آپدیت‌ها را در کسری از ثانیه دریافت کنید.</p>
                </div>

                <div class="p-8 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-2xl hover:shadow-emerald-500/10">
                    <div class="w-14 h-14 bg-emerald-600/10 text-emerald-600 rounded-2xl flex items-center justify-center mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M21 12H3"/><path d="M12 3v18"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-4">طراحی مدرن RTL</h3>
                    <p class="text-slate-600 leading-relaxed">رابط کاربری کاملاً بهینه شده برای زبان فارسی با استفاده از فونت محبوب وزیر متن.</p>
                </div>

                <div class="p-8 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-2xl hover:shadow-amber-500/10">
                    <div class="w-14 h-14 bg-amber-600/10 text-amber-600 rounded-2xl flex items-center justify-center mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-4">امنیت و نظارت</h3>
                    <p class="text-slate-600 leading-relaxed">سیستم پیشرفته نظارت بر محتوا برای حفظ سلامت فضای گفتگو و امنیت کاربران.</p>
                </div>
            </div>
        </div>
    </div>
</div>
