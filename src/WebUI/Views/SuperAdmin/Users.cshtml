@model IEnumerable<danialNewsNetX.Domain.Entities.AppUser>
@{
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <header>
        <h2 class="text-3xl font-bold text-white">مدیریت کاربران</h2>
        <p class="text-slate-400">کنترل نقش‌ها، وضعیت تایید و دسترسی کاربران</p>
    </header>

    <div class="bg-slate-800 rounded-2xl border border-slate-700 overflow-hidden">
        <table class="w-full text-right">
            <thead class="bg-slate-700/50">
                <tr>
                    <th class="px-6 py-4 text-slate-300 font-medium">کاربر</th>
                    <th class="px-6 py-4 text-slate-300 font-medium">وضعیت</th>
                    <th class="px-6 py-4 text-slate-300 font-medium">عملیات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-700">
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="px-6 py-4">
                            <div class="font-bold">@user.UserName</div>
                            <div class="text-xs text-slate-500">@user.Email</div>
                        </td>
                        <td class="px-6 py-4">
                            @if (user.IsVerified)
                            {
                                <span class="bg-blue-500/10 text-blue-400 px-3 py-1 rounded-full text-xs font-bold">تایید شده</span>
                            }
                            else
                            {
                                <span class="bg-slate-700 text-slate-400 px-3 py-1 rounded-full text-xs">معمولی</span>
                            }
                        </td>
                        <td class="px-6 py-4 flex gap-2">
                            <form asp-action="ToggleVerification" asp-route-userId="@user.Id" method="post">
                                <button type="submit" class="text-xs bg-slate-700 hover:bg-slate-600 px-3 py-1 rounded-lg transition-colors">تغییر وضعیت تایید</button>
                            </form>
                            <form asp-action="BanUser" asp-route-userId="@user.Id" method="post">
                                <button type="submit" class="text-xs bg-rose-600/20 text-rose-400 hover:bg-rose-600/30 px-3 py-1 rounded-lg transition-colors">مسدود سازی</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
