@model danialNewsNetX.Application.Admin.Queries.TelemetryDto
@{
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <header>
        <h2 class="text-3xl font-bold text-white">داشبورد سیستم</h2>
        <p class="text-slate-400">نمای کلی وضعیت سلامت و عملکرد پلتفرم</p>
    </header>

    <!-- Telemetry Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-gradient-to-br from-indigo-600 to-indigo-700 p-6 rounded-2xl shadow-lg shadow-indigo-900/20">
            <h3 class="text-indigo-100 text-sm font-medium">اتصالات SignalR</h3>
            <div class="mt-2 text-3xl font-bold text-white">@Model.ActiveWebSockets</div>
            <div class="mt-1 text-indigo-200 text-xs">اتصالات فعال بلادرنگ</div>
        </div>

        <div class="bg-gradient-to-br from-emerald-600 to-emerald-700 p-6 rounded-2xl shadow-lg shadow-emerald-900/20">
            <h3 class="text-emerald-100 text-sm font-medium">Cache Hit Rate</h3>
            <div class="mt-2 text-3xl font-bold text-white">@Model.RedisCacheHitRate.ToString("F1")%</div>
            <div class="mt-1 text-emerald-200 text-xs">عملکرد حافظه Redis</div>
        </div>

        <div class="bg-gradient-to-br from-amber-600 to-amber-700 p-6 rounded-2xl shadow-lg shadow-amber-900/20">
            <h3 class="text-amber-100 text-sm font-medium">استفاده از DB Pool</h3>
            <div class="mt-2 text-3xl font-bold text-white">@Model.DbConnectionPoolUsage.ToString("F1")%</div>
            <div class="mt-1 text-amber-200 text-xs">ظرفیت اتصالات PostgreSQL</div>
        </div>

        <div class="bg-gradient-to-br from-rose-600 to-rose-700 p-6 rounded-2xl shadow-lg shadow-rose-900/20">
            <h3 class="text-rose-100 text-sm font-medium">مصرف حافظه</h3>
            <div class="mt-2 text-3xl font-bold text-white">@Model.MemoryUsageMb MB</div>
            <div class="mt-1 text-rose-200 text-xs">میزان استفاده از RAM سرور</div>
        </div>
    </div>

    <!-- Announcement Form -->
    <div class="bg-slate-800 p-8 rounded-2xl border border-slate-700">
        <h3 class="text-xl font-bold text-white mb-4">اعلان جهانی سیستم</h3>
        <form asp-action="SendAnnouncement" method="post" class="flex gap-4">
            <input type="text" name="message" placeholder="متن اعلان را اینجا وارد کنید..."
                   class="flex-1 bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500" required />
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-3 rounded-xl font-bold transition-colors">
                ارسال به همه
            </button>
        </form>
    </div>
</div>
